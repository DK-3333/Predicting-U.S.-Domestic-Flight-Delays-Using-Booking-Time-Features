      <column caption='Late Rate By Carrier' datatype='real' name='[Calculation_5071756877447458816]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [op_unique_carrier] : AVG([is_late]) }' />
      </column>
      <column caption='Late Band' datatype='string' name='[Calculation_5071756877447643137]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_5071756877447458816] &gt;= [Parameters].[Parameter 1] THEN &quot;&gt;= Threshold&quot;&#10;ELSE &quot;&lt; Threshold&quot;&#10;END' />
      </column>
      <column caption='Weekend' datatype='string' name='[Calculation_5071756877451620354]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [day_of_week] IN (6,7) THEN &quot;Weekend&quot; ELSE &quot;Weekday&quot; END' />
      </column>
      <column caption='Late/On_time' datatype='string' name='[Calculation_5071756877455568900]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [is_late] = 1 THEN &quot;Late&quot; ELSE &quot;On-time&quot; END' />
      </column>
      <column aggregation='None' datatype='integer' name='[Pred Xgboost (bin)]' role='dimension' type='quantitative'>
